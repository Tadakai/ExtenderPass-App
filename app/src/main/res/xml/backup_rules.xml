<?xml version="1.0" encoding="utf-8"?>
<!--
    ExtenderPass stores NO user data, so all backup is excluded.
    The app is entirely stateless — the output is derived deterministically from the input.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
